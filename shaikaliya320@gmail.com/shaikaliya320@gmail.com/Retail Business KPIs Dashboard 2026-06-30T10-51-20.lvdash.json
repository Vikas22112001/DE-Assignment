{
  "datasets": [
    {
      "name": "revenue_summary",
      "displayName": "Revenue Summary",
      "queryLines": [
        "SELECT\n",
        "  SUM(total_revenue) as total_revenue,\n",
        "  SUM(total_orders) as total_orders,\n",
        "  SUM(total_transactions) as total_transactions\n",
        "FROM\n",
        "  retail.gold.gold_total_revenue"
      ]
    },
    {
      "name": "top_products",
      "displayName": "Top Products",
      "queryLines": [
        "SELECT\n",
        "  product_name,\n",
        "  total_revenue,\n",
        "  sales_rank\n",
        "FROM\n",
        "  retail.gold.gold_top_products\n",
        "WHERE\n",
        "  sales_rank <= 10\n",
        "ORDER BY\n",
        "  sales_rank"
      ]
    },
    {
      "name": "return_rate_summary",
      "displayName": "Return Rate Summary",
      "queryLines": [
        "SELECT\n",
        "  AVG(return_rate_pct) as avg_return_rate\n",
        "FROM\n",
        "  retail.gold.gold_return_rate"
      ]
    },
    {
      "name": "aov_trend",
      "displayName": "AOV Trend",
      "queryLines": [
        "SELECT\n",
        "  snapshot_date,\n",
        "  avg_order_value\n",
        "FROM\n",
        "  retail.gold.gold_avg_order_value\n",
        "ORDER BY\n",
        "  snapshot_date"
      ]
    },
    {
      "name": "revenue_trend",
      "displayName": "Revenue Trend",
      "queryLines": [
        "SELECT\n",
        "  snapshot_date,\n",
        "  total_revenue\n",
        "FROM\n",
        "  retail.gold.gold_total_revenue\n",
        "ORDER BY\n",
        "  snapshot_date"
      ]
    },
    {
      "name": "top_customers",
      "displayName": "Top Customers",
      "queryLines": [
        "SELECT\n",
        "  full_name,\n",
        "  total_revenue,\n",
        "  total_orders,\n",
        "  avg_order_value,\n",
        "  revenue_rank\n",
        "FROM\n",
        "  retail.gold.gold_top_customers\n",
        "WHERE\n",
        "  revenue_rank <= 10\n",
        "ORDER BY\n",
        "  revenue_rank"
      ]
    },
    {
      "name": "category_distribution",
      "displayName": "Category Distribution",
      "queryLines": [
        "SELECT\n",
        "  category_name,\n",
        "  COUNT(*) as product_count\n",
        "FROM\n",
        "  retail.gold.gold_top_products\n",
        "GROUP BY\n",
        "  category_name"
      ]
    }
  ],
